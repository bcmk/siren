#!/usr/bin/env bash
set -euo pipefail

cur="$(dirname "$(readlink -f "$0")")"
cd "$cur/.."

SIREN_BOT_VERSION="${1:-$(git describe --tags)}"
SIREN_BOT_VERSION="${SIREN_BOT_VERSION#v}"
go build -o cmd/bot/bot -ldflags="-s -X 'github.com/bcmk/siren/v2/lib/cmdlib.Version=${SIREN_BOT_VERSION}'" ./cmd/bot
