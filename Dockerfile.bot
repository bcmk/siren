FROM golang:1.26.1-alpine AS gobuilder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
RUN apk add --no-cache bash
COPY cmd/bot/ cmd/bot/
COPY internal/ internal/
COPY lib/ lib/
COPY scripts/build-bot scripts/build-bot
ARG SIREN_VERSION=devel
ENV CGO_ENABLED=0
ENV GOFLAGS=-trimpath
RUN ./scripts/build-bot "$SIREN_VERSION"

FROM alpine:3.22
WORKDIR /app
RUN apk add --no-cache ca-certificates
COPY res/ ./res/
COPY --from=gobuilder /app/cmd/bot/bot ./cmd/bot/bot
ENTRYPOINT ["./cmd/bot/bot"]
