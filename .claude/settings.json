{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "xhigh",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "deny": [
      "Read(//**/*.ignore)",
      "Read(//**/*.ignore.*)",
      "Read(//**/.idea/**)"
    ],
    "allow": [
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch",
      "Read(/tmp/**)",
      "Write(/tmp/**)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go mod graph *)",
      "Bash(go mod tidy *)",
      "Bash(go list *)",
      "Bash(go fmt *)",
      "Bash(go doc *)",
      "Bash(go env *)",
      "Bash(go vet *)",
      "Bash(go version *)",
      "Bash(gopls *)",
      "Bash(gofmt *)",
      "Bash(golangci-lint run *)",
      "Bash(goimports *)",
      "Bash(git add *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git status *)",
      "Bash(git ls-tree *)",
      "Bash(git mv *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(printf *)",
      "Bash(xxd *)",
      "Bash(curl *)",
      "Bash(prettier *)",
      "Bash(psql *)",
      "Bash(rm *)",
      "Bash(echo *)",
      "Bash(docker version *)",
      "Bash(docker info *)",
      "Bash(docker ps *)",
      "Bash(cmd/schema-dump/schema-dump)",
      "Bash(scripts/publish-bot)",
      "Bash(scripts/publish-adapter-mfc)",
      "Bash(scripts/build-diagram)",
      "Bash(pkill -f cmd/adapter-mfc/adapter-mfc)",
      "Bash(./adapter-mfc *)",
      "Bash(dot *)",
      "Bash(identify *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/no-bare-go-build.sh"
          }
        ]
      }
    ]
  }
}
